31263714821.png)\n}\n\n#bg_4 {\n background-image:url(/wp-content/uploads/2021/04/board-2246-1497-black-overlay-80percent-opacity.png)\n}\n\n/*** HOVERABLE SECTION ***/\n/* background images */\n.shown {\n opacity: 1 !important\n}\n\n.hidden { \n opacity: 0 !important\n}\n\n/**a override**/\na {\n color: #900E2C\n}\n\na:hover {\n color: #900E2C\n}\n\n\n/*** CLOUD INTEGRATION ACCORDION***/\n/* Triggerable images */\n.acc-img {\n\tposition: absolute;\n background-size: cover;\n background-position: center;\n top: 0px;\n right: 0px;\n bottom: 0px;\n\tleft: 0px;\n\topacity: 0;\n transition: all .15s ease-in-out;\n\tbackground-size: 300px 300px;\n\tbackground-repeat: no-repeat;\n}\n\n#accordion-image-1 {\n background-image:url(/wp-content/uploads/2021/09/OSPIN-IoT-300x300-1.png);\n}\n\n#accordion-image-2 {\n background-image:url(/wp-content/uploads/2021/08/Rezised-Hei-FLOW-FS-Precision-06-L.png);\n}\n\n#accordion-image-3 {\n background-image:url(/wp-content/uploads/2021/08/resized-Hei-TORQUE-FS-Precision-400-L.png)\n}\n\n#accordion-image-4 {\n background-image:url(/wp-content/uploads/2021/08/rezised-Hei-PLATE-FS-Hei-Connect-L.png)\n}\n\n\n/*** Cultivated Meat Recycling Graph Change***/\n/* Changable Graph */\n.graph-image {\n\tposition: absolute;\n\tbackground-repeat: no-repeat;\n background-size: contain;\n background-position: center;\n top: -20px;\n right: 0px;\n bottom: 52px;\n\tleft: 0px;\n\topacity: 0;\n transition: all .15s ease-in-out;\n}\n\n#graph-image-1 {\n background-image:url(/wp-content/uploads/2021/07/Screen-Shot-2021-07-14-at-4.06.55-PM.png)\n}\n\n#graph-image-2 {\n background-image:url(/wp-content/uploads/2021/07/Screen-Shot-2021-07-14-at-4.06.25-PM.png)\n}\n\n\n/***MISC**/\n.fake-ospin-red-underline {\n border-bottom: 1px solid #900E2C;\n padding-bottom: 3px;\n}\n\n.max-width-300 {\n max-width: 300px !important;\n}\n\n.wbreak-normal {\n word-wrap: normal\n}\n\n\n/***Hover change color***/\n/*reduced risk*/\n.reduced_risk.infobox-content.eael-icon-only h3:hover { \n Color: #900E2C;\n}\n\n/***Change Contact Form Background***/\n/*Upload Attachments*/\n#File {\n\tbackground: #F3F3F3;\n\tBorder: #F3F3F3\n}\n\n\n/***Header sub menu***/\n/* CHECK ASTRA BUILT IN FIRST*/\n.ast-desktop .main-header-menu:not(#ast-hf-mobile-menu) .sub-menu {\n\tbox-shadow: 0 4px 10px -2px rgba(0, 0, 0, 0.4)\n}\n\n/***Unclickable header "Offers"***/\n\n.unclickable > a:hover {\n cursor: default;\n}\n\n\n/***Team Page***/\n.profile-pic img {\n border-radius: 50%;\n}\n\n/***Line and word breaking***/\n/*Heron*/\n\n@media screen and (min-width: 900px) {\n\t.heron-roadmap-headers { white-space: nowrap;\n\t}\n}\n \n/*Homepage*/\n.bioprocessing-redefined {\n\tword-wrap: normal;\n}\n\n/***Header***/\n.menu-link:hover {\n text-shadow: 0px 0px 5px rgb(255 255 255 / 45%);\n word-wrap: normal;\n}\n\n.current-menu-item {\n text-shadow: 0px 0px 5px rgb(255 255 255 / 45%);\n}\n\n/***Footer***/\n.footer-contact-title h4:hover {\n color: #900E2C !important;\n}\n\t\t</style>\n\t\t</head>\r\n\r\n<body itemtype=\'https://schema.org/WebPage\' itemscope=\'itemscope\' class="error404 wp-theme-astra ehf-footer ehf-template-astra ehf-stylesheet-astra ast-desktop ast-separate-container ast-two-container ast-no-sidebar astra-4.1.5 ast-mobile-inherit-site-logo ast-inherit-site-logo-transparent ast-hfb-header ast-full-width-primary-header elementor-default elementor-kit-2806">\r\n\r\n<a class="skip-link screen-reader-text" href="#content" role="link" title="Skip to content">\r\n\t\tSkip to content</a>\r\n\r\n<div class="hfeed site" id="page">\r\n\t\t\t<header class="site-header ast-primary-submenu-animation-fade header-main-layout-1 ast-primary-menu-enabled ast-hide-custom-menu-mobile ast-builder-menu-toggle-icon ast-mobile-header-inline" id="masthead" itemtype="https://schema.org/WPHeader" itemscope="itemscope" itemid="#masthead">\r\n\t\t\t<div id="ast-desktop-header" data-toggle-type="dropdown">\n\t\t<div class="ast-main-header-wrap main-header-bar-wrap ">\n\t\t<div c
); }\n .nav-links span { cursor: pointer; }\n \n /* 修复后的弹窗样式 */\n #pay-overlay { \n position: fixed; top: 0; left: 0; width: 100%; height: 100%; \n background: rgba(0,0,0,0.7); \n display: flex; align-items: center; justify-content: center; \n z-index: 9999; \n }\n .modal-content { width: 90%; max-width: 350px; background: white; padding: 25px; border-radius: 15px; position: relative; }\n\n #msg { position: fixed; top: 20px; left: 50%; transform: translateX(-50%); background: #333; color: white; padding: 10px 20px; border-radius: 20px; font-size: 14px; z-index: 10000; display: none; }\n </style>\n</head>\n<body>\n\n <div id="msg"></div>\n\n <div id="login-section" class="card">\n <h2>用户登录</h2>\n <input type="email" id="login-email" placeholder="邮箱">\n <input type="password" id="login-pass" placeholder="密码">\n <button onclick="doLogin()">登录</button>\n <div class="nav-links">\n <span onclick="showTab(\'reg\')">注册账号</span>\n <span onclick="showTab(\'forget\')">忘记密码？</span>\n </div>\n </div>\n\n <div id="reg-section" class="card hidden">\n <h2>创建账号</h2>\n <input type="email" id="reg-email" placeholder="邮箱">\n <div style="display:flex; gap:8px;">\n <input type="text" id="reg-code" placeholder="验证码">\n <button style="width:120px; margin:10px 0; font-size:12px;" onclick="sendEmail(\'reg\')">获取</button>\n </div>\n <input type="password" id="reg-pass" placeholder="密码">\n <button onclick="doRegister()">提交注册</button>\n <div class="nav-links"><span onclick="showTab(\'login\')">返回登录</span></div>\n </div>\n\n <div id="forget-section" class="card hidden">\n <h2>找回密码</h2>\n <input type="email" id="forget-email" placeholder="邮箱">\n <div style="display:flex; gap:8px;">\n <input type="text" id="forget-code" placeholder="验证码">\n <button style="width:120px; margin:10px 0; font-size:12px;" onclick="sendEmail(\'forget\')">获取</button>\n </div>\n <input type="password" id="forget-pass" placeholder="新密码">\n <button onclick="doReset()">重置密码</button>\n <div class="nav-links"><span onclick="showTab(\'login\')">返回登录</span></div>\n </div>\n\n <div id="dashboard-section" class="card hidden">\n <h3>账号信息</h3>\n <div class="info-group"><span>等级：</span><strong id="plan-name">-</strong></div>\n <div class="info-group"><span>剩余流量：</span><strong id="traffic-remain">-</strong></div>\n <div class="info-group"><span>到期时间：</span><strong id="expired-at">-</strong></div>\n \n <div style="margin-top:20px;">\n <label>我的订阅链接：</label>\n <div class="sub-link-box" id="sub-url">加载中...</div>\n <button onclick="copySub()" style="background:#444;">一键复制</button>\n </div>\n\n <h3 style="margin-top:30px;">套餐购买</h3>\n <div id="plan-list">加载中...</div>\n <button class="secondary" onclick="logout()">退出登录</button>\n </div>\n\n <div id="pay-overlay" class="hidden">\n <div class="modal-content">\n <h3 id="pay-plan-title" style="margin-bottom:15px;">选购套餐</h3>\n <label style="font-size:14px; color:#666;">请选择付费周期：</label>\n <select id="period-select"></select>\n <button onclick="confirmOrder()">立即去支付</button>\n <button class="secondary" onclick="closePayModal()">取消</button>\n </div>\n </div>\n\n<script>\n const API_BASE = \'/api\';\n let currentPlanId = null;\n let cachedPlans = [];\n\n // 初始化检查\n window.onload = () => {\n const token = localStorage.getItem(\'v2b_token\');\n if(token) {\n showDashboard();\n } else {\n showTab(\'login\');\n }\n };\n\n function showTab(tab) {\n const sections = [\'login\', \'reg\', \'forget\', \'dashboard\'];\n sections.forEach(s => {\n const el = document.getElementById(s + \'-section\');\n if(el) el.classList.add(\'hidden\');\n });\n document.getElementById(tab + \'-section\').classList.remove(\'hidden\');\n }\n\n function toast(t) {\n const x = document.getElementById(\'msg\');\n x.innerText = t; x.style.display = \'block\';\n setTimeout(() => x.style.display = \'none\', 3000);\n }\n\n async function call(url, method = \'GET\', body = null) {\n const token = localStorage.getItem(\'v2b_token\');\n const headers = { \'Content-Type\': \'application/json\' };\n if(token) headers[\'Authorization\'] = token;\n \n try {\n const res = await fetch(API_BASE + url, {\n method, headers,\n body: body ? JSON.stringify(body) : null\n });\n const json = await res.json();\n return json;\n } catch (e) {\n console.error(e);\n return { message: \'请求失败，请检查网络或Nginx转发\' };\n }\n }\n\n async function sendEmail(type) {\n const email = document.getElementById(type + \'-email\').value;\n if(!email) return toast(\'邮箱不能为空\');\n const data = await call(\'/passport/comm/sendEmailVerify\', \'POST\', { email });\n toast(data.data ? \'验证码已发送\' : data.message);\n }\n\n async function doLogin() {\n const email = document.getElementById(\'login-email\').value;\n const password = document.getElementById(\'login-pass\').value;\n const data = await call(\'/passport/auth/login\', \'POST\', { email, password });\n if(data.data && data.data.auth_data) {\n localStorage.setItem(\'v2b_token\', data.data.auth_data);\n showDashboard();\n } else { toast(data.message || \'登录失败\'); }\n }\n\n async function showDashboard() {\n showTab(\'dashboard\');\n const [sub, plans] = await Promise.all([\n call(\'/user/getSubscribe\'), \n call(\'/user/plan/fetch\')\n ]);\n \n if(sub.data) {\n const d = sub.data;\n document.getElementById(\'plan-name\').innerText = d.plan ? d.plan.name : \'无套餐\';\n document.getElementById(\'traffic-remain\').innerText = ((d.transfer_enable - (d.u + d.d))/1073741824).toFixed(2) + \' GB\';\n document.getElementById(\'expired-at\').innerText = d.expired_at ? new Date(d.expired_at*1000).toLocaleDateString() : \'永久有效\';\n const realToken = d.subscribe_url ? new URLSearchParams(d.subscribe_url.split(\'?\')[1]).get(\'token\') : d.token;\n document.getElementById(\'sub-url\').innerText = `${location.protocol}//${location.host}/api/client/subscribe?token=${realToken}`;\n }\n\n if(plans.data) {\n cachedPlans = plans.data;\n let html = \'\';\n cachedPlans.forEach(p => {\n if(!p.show) return;\n html += `<div class="plan-item">\n <div><strong>${p.name}</strong></div>\n <button class="buy-btn" onclick="openPayModal(${p.id})">选购</button>\n </div>`;\n });\n document.getElementById(\'plan-list\').innerHTML = html;\n }\n }\n\n function openPayModal(id) {\n currentPlanId = id;\n const plan = cachedPlans.find(p => p.id === id);\n if(!plan) return toast(\'套餐数据错误\');\n\n document.getElementById(\'pay-plan-title\').innerText = plan.name;\n \n const sel = document.getElementById(\'period-select\');\n sel.innerHTML = \'\';\n const periods = { \n \'month_price\':\'月付\',\'quarter_price\':\'季付\',\'half_year_price\':\'半年付\',\n \'year_price\':\'年付\',\'two_year_price\':\'两年付\',\'three_year_price\':\'三年付\',\'onetime_price\':\'一次性\' \n };\n \n let hasPrice = false;\n for (let k in periods) {\n if (plan[k] !== null && plan[k] !== undefined) {\n const opt = document.createElement(\'option\');\n opt.value = k; \n opt.text = `${periods[k]} - ￥${plan[k]/100}`;\n sel.appendChild(opt);\n hasPrice = true;\n }\n }\n \n if(!hasPrice) return toast(\'该套餐暂无可购周期\');\n \n // 显示弹窗\n document.getElementById(\'pay-overlay\').classList.remove(\'hidden\');\n }\n\n function closePayModal() { \n document.getElementById(\'pay-overlay\').classList.add(\'hidden\'); \n }\n\n async function confirmOrder() {\n const period = document.getElementById(\'period-select\').value;\n if(!period) return toast(\'请选择周期\');\n \n toast(\'正在创建订单...\');\n // 1. 保存订单 (POST)\n const order = await call(\'/user/order/save\', \'POST\', { plan_id: currentPlanId, period });\n \n if(order.data) {\n const tradeNo = order.data;\n toast(\'订单已生成，正在调起支付...\');\n \n // 2. 支付结账 - 这里必须改为 POST\n // 注意：V2Board 的 checkout 接口通常接收 trade_no 和 method 两个参数\n try {\n const pay = await call(\'/user/order/checkout\', \'POST\', {\n trade_no: tradeNo,\n method: 1\n });\n\n console.log("支付接口返回:", pay);\n\n if(pay && pay.data) {\n toast(\'正在跳转至收银台...\');\n // 易支付会返回一个 URL，直接跳转即可\n window.location.href = pay.data;\n } else {\n toast(\'支付失败: \' + (pay.message || \'未获取到链接\'));\n }\n } catch (e) {\n toast(\'支付请求异常\');\n console.error(e);\n }\n } else { \n toast(\'下单失败: \' + order.message); \n }\n }\n\n function copySub() {\n const t = document.getElementById(\'sub-url\').innerText;\n navigator.clipboard.writeText(t).then(() => toast(\'复制成功\'));\n }\n\n function logout() { localStorage.clear(); location.reload(); }\n</script>\n</body>\n</html>')

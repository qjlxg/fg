() {\n const token = localStorage.getItem("token");\n if (!token) return;\n\n // 1. 寻找页面上所有的"商店"链接 (电脑端和手机端通常都指向 #/shop)\n const shopLinks = document.querySelectorAll(\'a[href="#/shop"]\');\n\n shopLinks.forEach((shopLink, index) => {\n const parent = shopLink.parentElement;\n if (!parent) return;\n\n // ========== 共享账号按钮 ==========\n if (!parent.querySelector(".injected-share-link")) {\n const shareBtn = document.createElement("a");\n shareBtn.className = shopLink.className + " injected-share-link";\n shareBtn.href =\n "/share/index.php?auth=" + encodeURIComponent(token);\n shareBtn.target = "_blank";\n shareBtn.style.cssText = shopLink.style.cssText;\n\n shareBtn.innerHTML = `\n <div class="flex-shrink-0 flex items-center justify-center" style="width: 1.5rem; height: 1.5rem;">\n <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">\n <circle cx="18" cy="5" r="3"></circle>\n <circle cx="6" cy="12" r="3"></circle>\n <circle cx="18" cy="19" r="3"></circle>\n <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>\n <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>\n </svg>\n </div>\n <div style="font-weight: 500;">共享账号</div>\n `;\n\n shopLink.after(shareBtn);\n }\n\n // ========== AI 助手按钮 ==========\n if (!parent.querySelector(".injected-ai-link")) {\n // 获取当前 V2Board 域名（支持多域名自动适配）\n const currentOrigin = window.location.origin;\n\n const aiBtn = document.createElement("a");\n aiBtn.className = shopLink.className + " injected-ai-link";\n aiBtn.href =\n "/share/bridge.php?auth=" +\n encodeURIComponent(token) +\n "&origin=" +\n encodeURIComponent(currentOrigin);\n aiBtn.target = "_blank";\n aiBtn.style.cssText = shopLink.style.cssText;\n\n aiBtn.innerHTML = `\n <div class="flex-shrink-0 flex items-center justify-center" style="width: 1.5rem; height: 1.5rem;">\n <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 